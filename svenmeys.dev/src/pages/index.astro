---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const projects = [
  {
    name: 'Ticketron',
    url: 'https://github.com/svenmeys/ticketron',
    desc: 'Give it a ticket, get back a pull request. Autonomous code execution.',
    tag: 'Soon',
  },
  {
    name: 'Loop',
    url: '#',
    desc: 'Autonomous dev loop. Runs specs, validates ACs, keeps AI on track.',
    tag: 'OSS',
  },
  {
    name: 'AsyncBot',
    url: 'https://asyncbot.app',
    desc: 'Slack bot for team duty rotations. Know who\'s responsible without asking.',
    tag: 'Live',
  },
  {
    name: 'Context Battery',
    url: 'https://github.com/svenmeys/claude-context-battery',
    desc: 'Context window battery bar for Claude Code. Know before compaction hits.',
    tag: 'OSS',
  },
  {
    name: 'ws',
    url: 'https://github.com/svenmeys/ws',
    desc: 'VS Code workspace CLI. Helps AI find your projects.',
    tag: 'OSS',
  },
  {
    name: 'Shortmoji',
    url: 'https://github.com/svenmeys/shortmoji',
    desc: ':emoji: shortcodes everywhere. Chrome extension.',
    tag: 'OSS',
  },
  {
    name: 'Slopdrop',
    url: 'https://slopdrop.dev',
    desc: 'Finally, a home for your AI\'s output.',
    tag: 'Soon',
  },
  {
    name: 'Bifrost',
    url: 'https://github.com/svenmeys/bifrost',
    desc: 'One window, all projects, zero context switching.',
    tag: 'Idea',
  },
  {
    name: 'SmarterSchool',
    url: '#',
    desc: 'Smartschool wrapper for confused parents.',
    tag: 'Soon',
  },
];
---

<Base title="Sven Meys" description="Dad of 4. Building dev tools with AI teammates. One developer + AI should be able to do what used to take twenty.">
  <header class="hero">
    <img src="/sven.jpg" alt="Sven Meys" class="avatar" width="64" height="64" />
    <div>
      <h1>Sven Meys</h1>
      <p class="tagline">Dad of 4. Building dev tools between bedtimes.</p>
    </div>
  </header>

  <p class="thesis">One developer + AI teammates should be able to do what used to take a team of twenty. I'm building the tools to prove it.</p>

  <section>
    <h2>Projects</h2>
    <div class="cards">
      {projects.map(p => (
        <a href={p.url} class="card" target="_blank" rel="noopener">
          <div class="card-top">
            <strong>{p.name}</strong>
            <span class:list={['badge', `badge--${p.tag.toLowerCase()}`]}>{p.tag}</span>
          </div>
          <p>{p.desc}</p>
        </a>
      ))}
    </div>
  </section>

  {posts.length > 0 && (
    <section>
      <h2><a href="/blog">Writing</a></h2>
      <ul class="posts">
        {posts.slice(0, 5).map(post => (
          <li>
            <a href={`/blog/${post.id}`}>
              <time>{post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</time>
              <span>{post.data.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <footer>
    <a href="https://github.com/svenmeys" target="_blank" rel="noopener">GitHub</a>
    <a href="https://linkedin.com/in/svenmeys" target="_blank" rel="noopener">LinkedIn</a>
    <a href="https://x.com/svenmeys" target="_blank" rel="noopener">X</a>
    <a href="mailto:hello@svenmeys.dev">Email</a>
    <a href="https://ko-fi.com/svenmeys" target="_blank" rel="noopener" class="kofi">
      <img src="/kofi.svg" alt="" width="16" height="16" />
      Ko-fi
    </a>
  </footer>
</Base>

<style>
  /* Hero */
  .hero {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .avatar {
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 2px solid var(--accent-soft);
  }

  h1 { font-size: 1.375rem; margin-bottom: 0.125rem; }
  .tagline { color: var(--text-muted); font-size: 0.9375rem; }

  .thesis {
    font-size: 1.0625rem;
    line-height: 1.6;
    margin-bottom: 2.5rem;
    color: var(--text);
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
  }

  /* Section headers */
  h2 {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  h2 a { color: var(--text-muted); }
  h2 a:hover { color: var(--accent); }

  section { margin-bottom: 2.5rem; }

  /* Cards */
  .cards {
    display: grid;
    gap: 0.75rem;
  }

  .card {
    display: block;
    padding: 0.875rem 1rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text);
    transition: border-color 0.15s;
  }

  .card:hover {
    border-color: var(--accent);
    text-decoration: none;
  }

  .card-top {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .card strong {
    font-size: 1.0625rem;
    letter-spacing: 0.01em;
  }

  .card p {
    color: var(--text-muted);
    font-size: 0.8125rem;
    margin-top: 0.375rem;
    line-height: 1.5;
    padding-top: 0.375rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .badge {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.125rem 0.375rem;
    border-radius: 3px;
    background: var(--border);
    color: var(--text-muted);
  }

  .badge--live {
    background: var(--accent-soft);
    color: var(--accent);
  }

  .badge--oss {
    background: rgba(100, 200, 255, 0.1);
    color: #7ac4ff;
  }

  .badge--soon {
    background: rgba(255, 200, 50, 0.1);
    color: #e8b830;
  }

  .badge--idea {
    background: rgba(180, 130, 255, 0.1);
    color: #b482ff;
  }

  /* Posts */
  .posts { list-style: none; }
  .posts li { padding: 0.375rem 0; }

  .posts a {
    display: flex;
    gap: 1rem;
    align-items: baseline;
    color: var(--text);
  }

  .posts time {
    font-size: 0.8125rem;
    color: var(--text-muted);
    min-width: 85px;
  }

  /* Footer */
  footer {
    display: flex;
    gap: 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    font-size: 0.875rem;
  }

  footer a { color: var(--text-muted); }
  footer a:hover { color: var(--accent); }
  .kofi { display: inline-flex; align-items: center; gap: 0.25rem; }
  .kofi img { opacity: 0.6; }
  .kofi:hover img { opacity: 1; }
</style>
