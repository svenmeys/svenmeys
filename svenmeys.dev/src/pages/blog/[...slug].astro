---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={post.data.title} description={post.data.description}>
  <nav><a href="/blog">&larr; Blog</a></nav>

  <article>
    <header>
      <h1>{post.data.title}</h1>
      <time>{post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</Base>

<style>
  nav { margin-bottom: 2rem; }
  nav a { font-size: 0.875rem; color: var(--text-muted); }

  header { margin-bottom: 2rem; }
  h1 { font-size: 1.5rem; margin-bottom: 0.25rem; }
  time { font-size: 0.875rem; color: var(--text-muted); }

  .prose { line-height: 1.75; }
  .prose :global(h2) { font-size: 1.25rem; margin: 2rem 0 0.75rem; }
  .prose :global(h3) { font-size: 1.125rem; margin: 1.5rem 0 0.5rem; }
  .prose :global(p) { margin-bottom: 1rem; }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 1rem 1.5rem; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--border);
    padding-left: 1rem;
    color: var(--text-muted);
    margin: 1rem 0;
  }
  .prose :global(code) {
    font-size: 0.9em;
    background: var(--border);
    padding: 0.125rem 0.375rem;
    border-radius: 3px;
  }
  .prose :global(pre) {
    background: var(--border);
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
    margin: 1rem 0;
  }
  .prose :global(pre code) { background: none; padding: 0; }
  .prose :global(a) { color: var(--accent); }
</style>
